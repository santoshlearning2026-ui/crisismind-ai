# Application
APP_ENV=development
DEBUG=True
APP_NAME=CRISISMIND AI
APP_VERSION=1.0.0
SECRET_KEY=your-secret-key-change-in-production

# Database
DATABASE_URL=postgresql://crisismind_user:crisismind_password@localhost:5432/crisismind_db
DATABASE_ECHO=False
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# API Keys
GEMINI_API_KEY=your-gemini-api-key
OPENWEATHER_API_KEY=your-openweather-api-key
NEWS_API_KEY=your-news-api-key

# ChromaDB
CHROMADB_HOST=localhost
CHROMADB_PORT=8000
CHROMADB_COLLECTION=crisismind_vectors

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=True

# Security
ALLOWED_HOSTS=["localhost", "127.0.0.1"]
TRUST_PROXY=False

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/var/log/crisismind/app.log

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=CRISISMIND AI
NEXT_PUBLIC_DEBUG=true

# Email (optional)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@crisismind.ai

# Monitoring
SENTRY_DSN=
DATADOG_API_KEY=

# Feature Flags
FEATURE_WEBSOCKET=False
FEATURE_GRAPHQL=False
FEATURE_CACHING=True

# Model Configuration
MODEL_VERSION=1.0
MODEL_PATH=/app/models
MODEL_CACHE_SIZE=1000

# Agent Configuration
AGENT_TIMEOUT=30
AGENT_MAX_RETRIES=3
AGENT_BATCH_SIZE=100

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Cache
CACHE_TTL=3600
CACHE_MAX_SIZE=10000

# Performance
WORKER_COUNT=4
WORKER_TIMEOUT=60
KEEP_ALIVE=5
